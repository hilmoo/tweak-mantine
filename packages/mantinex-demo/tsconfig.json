{
  "include": ["./src", "../../@types"],
  "exclude": ["dist/lib", "./esm", "./cjs"],
  "compilerOptions": {
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist/lib",
    "target": "ES2015",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "composite": true
  }
}
