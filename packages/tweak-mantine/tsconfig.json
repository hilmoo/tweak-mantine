{
  "include": ["./src/**/*", "../../@types"],
  "exclude": ["dist"],
  "compilerOptions": {
    "rootDir": "src",
    "declaration": true,
    "declarationDir": "dist/lib",
    "target": "ES2015",
    "lib": ["DOM", "ESNext"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "emitDeclarationOnly": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "plugins": [
      {
        "name": "typescript-plugin-css-modules"
      }
    ]
  }
}
